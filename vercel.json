{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "web": {
      "entrypoint": ".",
      "framework": "vite",
      "routePrefix": "/"
    },
    "eve": {
      "entrypoint": ".",
      "framework": "eve",
      "routePrefix": "/_eve_internal/eve",
      "buildCommand": "npm run eve:build"
    }
  },
  "rewrites": [
    {
      "source": "/dwella/agent/:path*",
      "destination": "/_eve_internal/eve/dwella/agent/:path*"
    },
    {
      "source": "/eve/:path*",
      "destination": "/_eve_internal/eve/eve/:path*"
    },
    {
      "source": "/.well-known/workflow/:path*",
      "destination": "/_eve_internal/eve/.well-known/workflow/:path*"
    }
  ]
}
