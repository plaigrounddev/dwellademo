{
  "name": "dwellademo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "test": "node --test",
    "test:unit": "node --test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:unit && npm run build && npm run test:e2e",
    "verify:agent": "node scripts/verify-agent-workspace.mjs",
    "verify:agent:full": "npm run eve:build && node scripts/verify-eve-agent-full-function.mjs",
    "verify:realtime": "node scripts/verify-openai-realtime.mjs",
    "eve:info": "eve info",
    "eve:dev": "eve dev --no-ui --host 127.0.0.1 --port 3000",
    "eve:e2e": "npm run eve:build && node scripts/start-eve-e2e.mjs",
    "eve:build": "node scripts/patch-nf3-nft-interop.mjs && eve build",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.3",
    "@clerk/react": "^6.11.2",
    "@vitejs/plugin-react": "^5.0.0",
    "ai": "^7.0.5",
    "convex": "^1.42.0",
    "eve": "^0.17.1",
    "framer-motion": "^12.42.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.22.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "streamdown": "^2.5.0",
    "use-stick-to-bottom": "^1.1.6",
    "vite": "^8.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@clerk/testing": "^2.2.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@vercel/nft": "^1.10.2",
    "microsandbox": "^0.5.10",
    "typescript": "^6.0.3"
  }
